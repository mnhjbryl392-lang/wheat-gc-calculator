import cv2
import numpy as np
import matplotlib.pyplot as plt
from google.colab import files

# طلب رفع الصورة من الباحث
print("الرجاء رفع صورة حقل القمح الملتقطة بالدرون...")
uploaded = files.upload()

# الحصول على اسم الملف المرفوع تلقائياً
uploaded_file_name = list(uploaded.keys())[0]
print(f"✅ تم رفع الملف بنجاح باسم: {uploaded_file_name}")
# قراءة الصورة وتحويل أنظمة الألوان
img = cv2.imread(uploaded_file_name)
img_hsv = cv2.cvtColor(img, cv2.COLOR_BGR2HSV)
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

# تحديد نطاق اللون الأخضر السليم وعزله
lower_green = np.array([35, 40, 40])
upper_green = np.array([85, 255, 255])
green_mask = cv2.inRange(img_hsv, lower_green, upper_green)
# إظهار القناع (القمح السليم أبيض، والمصاب/التربة أسود)
plt.figure(figsize=(10, 6))
plt.imshow(green_mask, cmap='gray')
plt.title("Green Mask: Healthy (White) vs Damaged/Soil (Black)")
plt.axis('off')
plt.show()

# الحسابات الرقمية ونسب الملوحة
healthy_pixels = cv2.countNonZero(green_mask)
total_pixels = green_mask.size
healthy_percentage = (healthy_pixels / total_pixels) * 100
salinity_stress_percentage = 100 - healthy_percentage

print("\n" + "="*40)
print(f"📊 تقرير تحليل حقل القمح:")
print(f"🟩 نسبة القمح السليم: {healthy_percentage:.2f}%")
print(f"🚨 نسبة الإجهاد الملوحي والضرر: {salinity_stress_percentage:.2f}%")
print("="*40 + "\n")
# عكس القناع لتحديد المناطق المصابة والتربة
damaged_mask = cv2.bitwise_not(green_mask)

# تطبيق اللون الأحمر على المناطق المصابة فوق الصورة الأصلية
output_img = img_rgb.copy()
output_img[damaged_mask == 255] = [255, 0, 0]

# عرض الخريطة التحذيرية النهائية داخل Colab
plt.figure(figsize=(10, 6))
plt.imshow(output_img)
plt.title("Final Salinity Map (Damaged Areas in Red)")
plt.axis('off')
plt.show()

# حفظ الصورة النهائية في ملفات الكولاب
cv2.imwrite('final_salinity_map.jpg', cv2.cvtColor(output_img, cv2.COLOR_RGB2BGR))
print("💾 تم حفظ الخريطة التحذيرية بنجاح باسم: final_salinity_map.jpg")
# استدعاء أداة التنزيل من جوجل كولاب
from google.colab import files

print("⏳ جاري تجهيز وتحميل الخريطة التحذيرية...")
# تحميل الملف المحفوظ إلى جهازك مباشرة
files.download('final_salinity_map.jpg')
